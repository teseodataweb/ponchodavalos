<div class="site-content" id="content">

    <!-- SECTION 1: Hero -->
    <div class="pseo-hub-hero">
        <div class="container">
            <h1>Mercado Inmobiliario de Puerto Vallarta y Riviera Nayarit</h1>
            <p class="hero-subtitle">Análisis por zonas, tipos de propiedad y guías de inversión. Por Poncho Dávalos, Asociado AMPI Riviera Nayarit.</p>
            <div>
                <span class="badge-stat">2,255 propiedades</span>
                <span class="badge-stat">+10.2% plusvalía</span>
                <span class="badge-stat">82.7% ocupación</span>
                <span class="badge-stat">32% seguridad</span>
            </div>
            <div style="margin-top: 10px;">
                <span class="badge-ampi">Asociado AMPI Riviera Nayarit</span>
            </div>
        </div>
    </div>

    <!-- SECTION 2: Zona Centro -->
    {{#if zonaCentro.length}}
    <section class="hub-section hub-section-light">
        <div class="container">
            <div class="ot-heading text-center">
                <span>Análisis por Zona</span>
                <h2 class="main-heading">Zona Centro — Puerto Vallarta</h2>
            </div>
            <p class="text-center" style="max-width: 650px; margin: 0 auto 30px; color: #666;">
                Desde la Zona Romántica hasta el Centro Histórico: las zonas más consolidadas con alta demanda turística y rentas vacacionales.
            </p>
            <div class="row">
                {{#each zonaCentro}}
                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="hub-card">
                        <div class="card-zona">{{this.zona}}</div>
                        <div class="card-stat"><strong>{{this.precioMin}} — {{this.precioMax}}</strong> rango de precios</div>
                        {{#if this.roi}}
                        <div class="card-stat">ROI: <strong>{{this.roi}}%</strong></div>
                        {{/if}}
                        {{#if this.plusvalia}}
                        <div class="card-stat">Plusvalía: <strong>+{{this.plusvalia}}%</strong></div>
                        {{/if}}
                        <div class="card-link">
                            <a href="{{this.slug}}/">Ver análisis completo &rarr;</a>
                        </div>
                    </div>
                </div>
                {{/each}}
            </div>
        </div>
    </section>
    {{/if}}

    <!-- SECTION 3: Zona Norte -->
    {{#if zonaNorte.length}}
    <section class="hub-section hub-section-white">
        <div class="container">
            <div class="ot-heading text-center">
                <span>Riviera Nayarit</span>
                <h2 class="main-heading">Zona Norte — Riviera Nayarit / Bahía de Banderas</h2>
            </div>
            <p class="text-center" style="max-width: 650px; margin: 0 auto 20px; color: #666;">
                La zona de mayor crecimiento: nuevos desarrollos, infraestructura en expansión y alta plusvalía.
            </p>
            <div class="text-center" style="margin-bottom: 30px;">
                <span class="section-highlight">ROI 200.2%</span>
                <span class="section-highlight">+51.1% crecimiento poblacional</span>
            </div>
            <div class="row">
                {{#each zonaNorte}}
                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="hub-card">
                        <div class="card-zona">{{this.zona}}</div>
                        <div class="card-stat"><strong>{{this.precioMin}} — {{this.precioMax}}</strong> rango de precios</div>
                        {{#if this.roi}}
                        <div class="card-stat">ROI: <strong>{{this.roi}}%</strong></div>
                        {{/if}}
                        {{#if this.plusvalia}}
                        <div class="card-stat">Plusvalía: <strong>+{{this.plusvalia}}%</strong></div>
                        {{/if}}
                        <div class="card-link">
                            <a href="{{this.slug}}/">Ver análisis completo &rarr;</a>
                        </div>
                    </div>
                </div>
                {{/each}}
            </div>
        </div>
    </section>
    {{/if}}

    <!-- SECTION 4: Zona Sur -->
    {{#if zonaSur.length}}
    <section class="hub-section hub-section-light">
        <div class="container">
            <div class="ot-heading text-center">
                <span>Exclusividad</span>
