<style>
/* Hub Page Styles */
.pseo-hub-hero {
    background: #1a1a1a;
    color: #fff;
    padding: 80px 0 60px;
    text-align: center;
}
.pseo-hub-hero h1 {
    font-size: 2.4rem;
    font-weight: 700;
    margin-bottom: 15px;
}
.pseo-hub-hero .hero-subtitle {
    font-size: 17px;
    color: #ccc;
    max-width: 700px;
    margin: 0 auto 25px;
    line-height: 1.6;
}
.badge-stat {
    display: inline-block;
    background: #C9A227;
    color: #fff;
    padding: 6px 16px;
    border-radius: 4px;
    font-size: 14px;
    font-weight: 600;
    margin: 5px 4px;
}
.badge-ampi {
    display: inline-block;
    background: #1a1a1a;
    border: 1px solid #C9A227;
    color: #C9A227;
    padding: 6px 16px;
    border-radius: 4px;
    font-size: 13px;
    font-weight: 600;
    margin: 5px 4px;
}
.hub-section { padding: 50px 0; }
.hub-section-dark { background: #1a1a1a; color: #fff; }
.hub-section-light { background: #f8f8f8; }
.hub-section-white { background: #fff; }

.hub-card {
    background: #fff;
    border: 1px solid #e8e8e8;
    border-radius: 8px;
    padding: 25px 20px;
    margin-bottom: 20px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    height: 100%;
    display: flex;
    flex-direction: column;
}
.hub-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.12);
}
.hub-card-dark {
    background: #222;
    border-color: #333;
    color: #fff;
}
.hub-card-dark:hover {
    box-shadow: 0 8px 25px rgba(0,0,0,0.4);
}
.hub-card .card-zona {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 10px;
    color: #1a1a1a;
}
.hub-card-dark .card-zona { color: #fff; }
.hub-card .card-meta {
    font-size: 13px;
    color: #888;
    margin-bottom: 8px;
}
.hub-card .card-stat {
    font-size: 14px;
    color: #555;
    margin-bottom: 4px;
}
.hub-card-dark .card-stat { color: #ccc; }
.hub-card .card-stat strong {
    color: #C9A227;
    font-weight: 700;
}
.hub-card .card-link {
    margin-top: auto;
    padding-top: 12px;
}
.hub-card .card-link a {
    color: #C9A227;
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    transition: color 0.2s;
}
.hub-card .card-link a:hover {
    color: #a8841e;
    text-decoration: underline;
}
.hub-editorial-item {
    padding: 20px 0;
    border-bottom: 1px solid #e8e8e8;
}
.hub-editorial-item:last-child { border-bottom: none; }
.hub-editorial-item h4 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 6px;
}
.hub-editorial-item h4 a {
    color: #1a1a1a;
    text-decoration: none;
    transition: color 0.2s;
}
.hub-editorial-item h4 a:hover { color: #C9A227; }
.hub-editorial-item .excerpt {
    font-size: 14px;
    color: #666;
    line-height: 1.6;
    margin-bottom: 6px;
}
.hub-editorial-item .read-more {
    color: #C9A227;
    text-decoration: none;
    font-weight: 600;
    font-size: 13px;
}
.hub-editorial-item .read-more:hover { text-decoration: underline; }

.hub-en-list { list-style: none; padding: 0; }
.hub-en-list li {
    padding: 8px 0;
    border-bottom: 1px solid #333;
}
.hub-en-list li:last-child { border-bottom: none; }
.hub-en-list a {
    color: #C9A227;
    text-decoration: none;
    font-weight: 500;
}
.hub-en-list a:hover { text-decoration: underline; color: #fff; }

.cta-container {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 15px;
}
.cta-btn {
    display: inline-block;
    padding: 12px 20px;
    background-color: #2e2e2e;
    color: #ffffff;
    text-decoration: none;
    font-size: 16px;
    font-weight: 600;
    border-radius: 8px;
    transition: background-color 0.3s ease, transform 0.3s ease;
    text-align: center;
}
.cta-btn:hover {
    background-color: #444444;
    transform: scale(1.05);
    color: #ffffff;
    text-decoration: none;
}
.cta-principal { background-color: #2e2e2e; }
.cta-secundario { background-color: #4a4a4a; }
@media (max-width: 576px) {
    .cta-container { flex-direction: column; }
    .cta-btn { width: 100%; text-align: center; }
    .pseo-hub-hero h1 { font-size: 1.6rem; }
}
.section-highlight {
    display: inline-block;
    background: rgba(201,162,39,0.15);
    color: #C9A227;
    padding: 3px 12px;
    border-radius: 4px;
    font-size: 13px;
    font-weight: 600;
    margin-bottom: 15px;
}
</style>
