        <div class="hero-content">
            <div class="container">
                <h1>{{h1}}</h1>
                <p style="font-size: 18px; margin-bottom: 15px;">{{municipio}}, {{estado}}</p>
                <div>
                    <span class="badge-intent">{{tipoPropiedad}}</span>
                    {{#if intencion}}
                    <span class="badge-stat">{{intencion}}</span>
                    {{/if}}
                    {{#if roi}}
                    <span class="badge-stat" data-i18n="pseo.roiBadge">ROI {{roi}}%</span>
                    {{/if}}
                    {{#if badgeAMPI}}
                    <span class="badge-ampi">AMPI Certified</span>
                    {{/if}}
                </div>
            </div>
        </div>
    </div>

    <!-- SECTION 2: Market Data by Property Type -->
    <section class="services-single">
        <div class="container">
            <div class="space-40"></div>
            <div class="ot-heading text-center">
                <span data-i18n="pseo.marketDataLabel">{{#if isEnglish}}Market Intelligence{{else}}Inteligencia de Mercado{{/if}}</span>
                <h2 class="main-heading" data-i18n="pseo.marketDataTitle">{{tipoPropiedad}} — {{#if isEnglish}}Price Overview{{else}}Panorama de Precios{{/if}}</h2>
            </div>
            <div class="space-20"></div>
            <div class="row">
                <div class="col-lg-3 col-md-6 col-sm-6 mb-4">
                    <div class="market-card">
                        <div class="market-value">{{moneda}} {{precioMin}} — {{precioMax}}</div>
                        <div class="market-label" data-i18n="pseo.priceRange">{{#if isEnglish}}Price Range{{else}}Rango de Precios{{/if}}</div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6 col-sm-6 mb-4">
                    <div class="market-card">
                        <div class="market-value">{{roi}}%</div>
                        <div class="market-label" data-i18n="pseo.roiLabel">ROI {{#if isEnglish}}Annual{{else}}Anual{{/if}}</div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6 col-sm-6 mb-4">
                    <div class="market-card">
                        <div class="market-value">+{{plusvalia}}%</div>
                        <div class="market-label" data-i18n="pseo.plusvaliaLabel">{{#if isEnglish}}Appreciation{{else}}Plusvalia{{/if}}</div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6 col-sm-6 mb-4">
                    <div class="market-card">
                        <div class="market-value">{{saturacion}}%</div>
                        <div class="market-label" data-i18n="pseo.saturationLabel">{{#if isEnglish}}Market Saturation{{else}}Saturacion del Mercado{{/if}}</div>
                    </div>
                </div>
            </div>
            {{#if precioM2Min}}
            <div class="row justify-content-center">
                <div class="col-lg-6 col-md-8">
                    <div class="market-card" style="margin-top: 10px;">
                        <div class="market-value">{{moneda}} {{precioM2Min}} — {{precioM2Max}} / m&sup2;</div>
                        <div class="market-label" data-i18n="pseo.pricePerM2">{{#if isEnglish}}Price per m&sup2; for {{tipoPropiedad}}{{else}}Precio por m&sup2; para {{tipoPropiedad}}{{/if}}</div>
                    </div>
                </div>
            </div>
            {{/if}}
            <div class="space-40"></div>
        </div>
    </section>

    <!-- SECTION 3: Why This Property Type -->
    <section style="background-color: #f9f9f9;">
        <div class="container">
            <div class="space-40"></div>
            <div class="ot-heading text-center">
                <span data-i18n="pseo.whyTypeLabel">{{#if isEnglish}}Investment Analysis{{else}}Analisis de Inversion{{/if}}</span>
                <h2 class="main-heading" data-i18n="pseo.whyTypeTitle">{{#if isEnglish}}Why Choose{{else}}Por que elegir{{/if}} {{tipoPropiedad}}?</h2>
            </div>
            <div class="space-20"></div>
            <div class="row">
                <div class="col-lg-7 col-md-12">
                    <p style="font-size: 16px; line-height: 1.8;">{{porqueZona}}</p>
