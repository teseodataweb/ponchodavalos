<meta name="twitter:description" content="{{metaDesc}}" />
<meta name="twitter:image" content="{{ogImage}}" />

<link rel="canonical" href="{{fullUrl}}" />

<!-- Hreflang -->
<link rel="alternate" hreflang="en" href="{{fullUrl}}" />
<link rel="alternate" hreflang="es" href="{{fullUrl}}" />
<link rel="alternate" hreflang="x-default" href="{{fullUrl}}" />

<!-- Schema.org -->
<script type="application/ld+json">
{{{schemaOrg}}}
</script>

<!-- FAQPage Schema -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {{#each faqItems}}
    {
      "@type": "Question",
      "name": "{{#if ../isEnglish}}{{this.preguntaEn}}{{else}}{{this.pregunta}}{{/if}}",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "{{#if ../isEnglish}}{{this.respuestaEn}}{{else}}{{this.respuesta}}{{/if}}"
      }
    }{{#unless @last}},{{/unless}}
    {{/each}}
  ]
}
</script>

<!-- BreadcrumbList Schema -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://ponchodavalos.com.mx/"},
    {"@type": "ListItem", "position": 2, "name": "{{#if isEnglish}}Properties{{else}}Propiedades{{/if}}", "item": "https://ponchodavalos.com.mx/portfolio-four-column-wide.html"},
    {"@type": "ListItem", "position": 3, "name": "{{tipoPropiedad}}"}
  ]
}
</script>

