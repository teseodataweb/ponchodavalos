<style>
.cta-container {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 15px;
}
.cta-btn {
    display: inline-block;
    padding: 12px 20px;
    background-color: #2e2e2e;
    color: #ffffff;
    text-decoration: none;
    font-size: 16px;
    font-weight: 600;
    border-radius: 8px;
    transition: background-color 0.3s ease, transform 0.3s ease;
    text-align: center;
}
.cta-btn:hover {
    background-color: #444444;
    transform: scale(1.05);
    color: #ffffff;
    text-decoration: none;
}
.cta-principal { background-color: #2e2e2e; }
.cta-secundario { background-color: #4a4a4a; }
@media (max-width: 576px) {
    .cta-container { flex-direction: column; }
    .cta-btn { width: 100%; text-align: center; }
}

/* PSEO Property Type Styles */
.pseo-hero {
    position: relative;
    background-size: cover;
    background-position: center;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #fff;
}
.pseo-hero::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0,0,0,0.55);
}
.pseo-hero .hero-content { position: relative; z-index: 2; }
.pseo-hero h1 { font-size: 2.5rem; margin-bottom: 10px; }
.badge-stat {
    display: inline-block;
    background: #C9A227;
    color: #fff;
    padding: 6px 16px;
    border-radius: 4px;
    font-size: 14px;
    font-weight: 600;
    margin: 5px 4px;
}
.badge-ampi {
    display: inline-block;
    background: #1a1a1a;
    border: 1px solid #C9A227;
    color: #C9A227;
    padding: 6px 16px;
    border-radius: 4px;
    font-size: 13px;
    font-weight: 600;
    margin: 5px 4px;
}
.badge-intent {
    display: inline-block;
    background: transparent;
    border: 2px solid #C9A227;
    color: #fff;
    padding: 6px 16px;
    border-radius: 4px;
    font-size: 14px;
    font-weight: 600;
    margin: 5px 4px;
    text-transform: uppercase;
    letter-spacing: 1px;
}
.market-card {
    background: #1a1a1a;
    border: 1px solid #333;
    border-radius: 8px;
    padding: 25px 20px;
    text-align: center;
    color: #fff;
    height: 100%;
}
.market-card .market-value {
    font-size: 1.8rem;
    font-weight: 700;
    color: #C9A227;
    margin-bottom: 5px;
}
.market-card .market-label {
    font-size: 14px;
    color: #ccc;
    text-transform: uppercase;
    letter-spacing: 1px;
}
.why-type-card {
    background: #fff;
    border: 1px solid #eee;
    border-radius: 8px;
    padding: 30px;
    height: 100%;
    transition: box-shadow 0.3s ease;
}
.why-type-card:hover {
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
}
.why-type-card .card-icon {
    font-size: 2rem;
    color: #C9A227;
    margin-bottom: 15px;
}
.why-type-card h5 {
    color: #1a1a1a;
    margin-bottom: 10px;
}
.why-type-card p {
    color: #666;
    font-size: 15px;
    line-height: 1.7;
}
.faq-item { border-bottom: 1px solid #ddd; }
.faq-item summary {
    padding: 18px 0;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    list-style: none;
    position: relative;
    padding-right: 30px;
}
.faq-item summary::after {
    content: '+';
    position: absolute;
    right: 0;
    top: 18px;
    font-size: 20px;
    color: #C9A227;
}
.faq-item[open] summary::after { content: '−'; }
.faq-item p { padding: 0 0 18px 0; color: #666; line-height: 1.7; }
.safety-section {
    background: #0d4d2b;
    color: #fff;
    padding: 30px;
    border-radius: 8px;
    text-align: center;
}
.safety-section .safety-value {
    font-size: 2rem;
    font-weight: 700;
    color: #C9A227;
}
</style>
